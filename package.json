{
  "name": "eat-what",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "EatWhat 食乜好 — a gamified spin-the-wheel PWA that decides where to eat",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "vue-tsc -b",
    "lint": "eslint .",
    "format": "prettier --write src/",
    "icons": "pwa-assets-generator --preset minimal-2023 public/logo.svg",
    "deploy": "pnpm build && pnpm dlx wrangler pages deploy dist --project-name eat-what"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "canvas-confetti": "^1.9.4",
    "dexie": "^4.4.4",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@tailwindcss/vite": "^4.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.19.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.0",
    "eslint": "^9.39.0",
    "eslint-plugin-vue": "^10.5.0",
    "fake-indexeddb": "^6.2.0",
    "prettier": "^3.9.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.9.2",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6",
    "workbox-build": "^7.4.1",
    "workbox-window": "^7.4.1"
  }
}
